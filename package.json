{
  "name": "devconnect-full-stack-platform",
  "version": "1.0.0",
  "private": true,
  "description": "DevConnect full-stack developer community platform with React, Express, MongoDB, JWT auth, posts, projects, network, search, dashboard, notifications, and image uploads.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "server": "npm run dev --workspace=server",
    "client": "npm run dev --workspace=client",
    "start": "npm run start --workspace=server",
    "seed": "npm run seed --workspace=server",
    "build": "npm run build --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
